{
	"version": "2.0.0",
	"inputs": [
		{
			"id": "buildType",
			"type": "pickString",
			"description": "Select the build configuration",
			"options": [
				"Debug",
				"Release"
			]
		}
	],
	"tasks": [
		{
			"label": "build ConduentResourceMonitor",
			"isBuildCommand": true,
			"command": "dotnet",
			"type": "process",
			"args": [
				"build", "${workspaceFolder}\\ConduentResourceMonitor.csproj",
				"-c", "${input:buildType}",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"presentation": {
				"clear": true,
				"echo": false,
				"showReuseMessage": false
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$msCompile"
		},
		{
			"label": "publish ConduentResourceMonitor (single file)",
			"dependsOrder": "sequence",
			"dependsOn": [
				"publish ConduentResourceMonitor (single file) - publish",
				"publish ConduentResourceMonitor (single file) - copy"
			],
			"problemMatcher": []
		},
		{
			"label": "publish ConduentResourceMonitor (single file) - publish",
			"hide": true,
			"command": "dotnet",
			"type": "process",
			"args": [
				"publish", "${workspaceFolder}\\ConduentResourceMonitor.csproj",
				"-c", "Release",
				"-r", "win-x64",
				"-p:PublishSingleFile=true",
				"/property:GenerateFullPaths=true",
				"/consoleloggerparameters:NoSummary"
			],
			"presentation": {
				"clear": true,
				"echo": false,
				"showReuseMessage": false
			},
			"problemMatcher": "$msCompile"
		},
		{
			"label": "publish ConduentResourceMonitor (single file) - copy",
			"hide": true,
			"type": "shell",
			"command": "powershell",
			"args": [
				"-Command",
				"$destinationDir = 'C:\\BTR\\Extensibility\\ConduentResource'; $sourcePath = '${workspaceFolder}\\bin\\Release\\net10.0-windows\\win-x64\\publish\\ConduentResourceMonitor.exe'; $destinationPath = Join-Path -Path $destinationDir -ChildPath 'ConduentResourceMonitor.exe'; if (-not (Test-Path -LiteralPath $destinationDir)) { New-Item -ItemType Directory -Path $destinationDir -Force | Out-Null }; Copy-Item -LiteralPath $sourcePath -Destination $destinationPath -Force"
			],
			"presentation": {
				"reveal": "silent"
			},
			"problemMatcher": []
		}
	]
}
